# Xirang 环境变量模板
# 复制为 .env.local 或 .env.production 后使用
# config.py 会根据 APP_ENV 自动加载对应的 .env.{APP_ENV} 文件

APP_ENV=local
LOG_LEVEL=INFO

BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/xirang
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173

STORAGE_MODE=local
UPLOAD_DIR=.data/uploads
MAX_FILE_SIZE_MB=50

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-nano-30b-a3b

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

PAGEINDEX_URL=http://localhost:8080/pageindex
PAGEINDEX_MOCK_FALLBACK=true

MINERU_URL=http://127.0.0.1:8300
MINERU_TIMEOUT_SECONDS=1800
MINERU_BACKEND=hybrid-auto-engine
MINERU_LANG_LIST=ch

WORKER_POLL_INTERVAL_SECONDS=5
WORKER_MAX_CONCURRENT_JOBS=3

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/oauth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/oauth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=http://localhost:8000/api/v1/auth/oauth/microsoft/callback
