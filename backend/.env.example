# Xirang Backend Environment Configuration
# Copy this file to .env and fill in your values

# =========================
# Runtime
# =========================
APP_ENV=local
LOG_LEVEL=INFO

# =========================
# Base URLs
# =========================
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# =========================
# Database & Security
# =========================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/xirang
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================
# CORS
# =========================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =========================
# Storage / Upload
# =========================
STORAGE_MODE=local
UPLOAD_DIR=.data/uploads
MAX_FILE_SIZE_MB=50

# =========================
# NVIDIA Build API (PRIMARY LLM PROVIDER)
# =========================
NVIDIA_API_KEY=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
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-nano-30b-a3b

# =========================
# OpenAI API (OPTIONAL - alternative to NVIDIA)
# =========================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# =========================
# PageIndex (self-hosted)
# =========================
PAGEINDEX_URL=http://localhost:8080
PAGEINDEX_API_KEY=

# =========================
# MinerU (document parsing)
# =========================
MINERU_URL=http://127.0.0.1:8300
MINERU_TIMEOUT_SECONDS=1800
MINERU_BACKEND=hybrid-auto-engine
MINERU_LANG_LIST=ch

# =========================
# Worker
# =========================
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_MAX_CONCURRENT_JOBS=3

# =========================
# OAuth - GitHub
# =========================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/oauth/github/callback

# =========================
# OAuth - Google
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/oauth/google/callback

# =========================
# OAuth - Microsoft
# =========================
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=http://localhost:8000/api/v1/auth/oauth/microsoft/callback