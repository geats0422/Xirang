# Xirang Backend Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/xirang

# Security
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI / OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# NVIDIA Build (optional, OpenAI-compatible)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-nano-30b-a3b

# PageIndex (self-hosted)
PAGEINDEX_URL=http://localhost:8080
PAGEINDEX_API_KEY=
PAGEINDEX_AUTO_START=true
PAGEINDEX_TIMEOUT_SECONDS=30
PAGEINDEX_STARTUP_TIMEOUT_SECONDS=30
PAGEINDEX_STARTUP_POLL_INTERVAL_SECONDS=1.0
PAGEINDEX_SUBPROCESS_LOG_LEVEL=warning
# Recommended: configure the real PageIndex launch command for local child-service startup.
# Available placeholders: {host}, {port}, {url}, {log_level}
# Example:
# PAGEINDEX_LAUNCH_COMMAND=pageindex serve --host {host} --port {port} --log-level {log_level}
PAGEINDEX_LAUNCH_COMMAND=
PAGEINDEX_LAUNCH_WORKDIR=
PAGEINDEX_LAUNCH_SHELL=true
# If no real launch command is configured, fall back to the in-repo mock server for local development.
PAGEINDEX_MOCK_FALLBACK=true

# Storage
STORAGE_MODE=local
UPLOAD_DIR=.data/uploads
MAX_FILE_SIZE_MB=50

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Worker
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_MAX_CONCURRENT_JOBS=3
