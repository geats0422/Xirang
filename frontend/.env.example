# API
# 留空表示走 Vite 代理（开发推荐）
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:8000

# Health Check
VITE_ENABLE_BACKEND_HEALTH_CHECK=false

# App Base URL（OAuth 回调等场景使用）
VITE_APP_BASE_URL=http://localhost:5173

# AI Model Config
VITE_DEFAULT_MODEL=gpt-4o-mini
VITE_MODEL_PROVIDER_CONFIG=[{"provider":"openai","baseUrl":"https://api.openai.com/v1","models":["gpt-4o-mini","gpt-4o"]},{"provider":"anthropic","baseUrl":"https://api.anthropic.com","models":["claude-3-5-sonnet"]}]